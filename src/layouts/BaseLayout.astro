---
interface Props {
	title?: string;
}

const { title = "Source Monster | The Future of Digital Execution" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />

		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- SEO & Trackers -->
		<meta
			name="description"
			content="Source Monster is a premium digital task force of elite freelancers. We deliver high-performance web development, alpha UI/UX design, and aggressive digital growth strategies."
		/>
		<meta
			name="keywords"
			content="web development, UI/UX design, digital marketing, SEO, freelancers, software solutions"
		/>

		<!-- Google Analytics (gtag.js) -->
		<script is:inline
			async
			src="https://www.googletagmanager.com/gtag/js?id=G-J17XMFEZDH"
		></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());
			gtag("config", "G-J17XMFEZDH");
			gtag("config", "G-N3TWWTZ276");
			gtag("config", "AW-323793960");
		</script>

		<!-- Meta Verifications -->
		<meta
			name="facebook-domain-verification"
			content="px5tptxaus7b2qvd9dftsaeyc63c43"
		/>
		<meta
			name="google-site-verification"
			content="O5Epj59DcBao74Z8cbYPfg5ZwYs5FUSbyzWhue5fF8E"
		/>
		<meta property="fb:pages" content="103794024703870" />

		<!-- Styles -->
		<link rel="stylesheet" href="/css/main.css" />

		<!-- Animation Libraries -->
		<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
		/>
	</head>
	<body class="bg-slate-50 text-slate-800 selection:bg-primary/30 selection:text-primary">
		<slot />

		<!-- Scripts -->
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
		<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
		<script is:inline src="https://unpkg.com/lucide@latest"></script>
		<script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>
		
		<script is:inline>
			// Initialize AOS
			document.addEventListener('DOMContentLoaded', function() {
				if (typeof AOS !== 'undefined') {
					AOS.init();
				}
				if (typeof lucide !== 'undefined') {
					lucide.createIcons();
				}
				if (typeof gsap !== 'undefined') {
					gsap.to("body", { opacity: 1, duration: 1 });
				}
			});
		</script>
	</body>
</html>

---
---
<!-- About Section -->
<section id="about" class="py-32 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            <div class="relative" data-aos="fade-right">
                <div class="absolute -top-10 -left-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl"></div>
                <img src="/assets/images/resource/about.png" alt="Source Monster Team" class="relative z-10 w-full rounded-[4rem] shadow-2xl shadow-slate-200" />
                <div class="absolute -bottom-10 -right-10 glass-card p-10 rounded-3xl animate-float">
                    <div class="text-4xl font-black text-primary mb-1">100%</div>
                    <div class="text-[10px] text-slate-500 uppercase tracking-widest font-bold">
                        Client Satisfaction
                    </div>
                </div>
            </div>
            <div data-aos="fade-left">
                <div class="text-primary font-bold tracking-widest uppercase mb-4">
                    Our DNA
                </div>
                <h2 class="text-5xl font-black font-heading leading-tight mb-8">
                    ENGINEERING SUCCESS <br /><span class="text-gradient">THROUGH EXPERTISE.</span>
                </h2>
                <p class="text-lg text-slate-600 leading-relaxed mb-10">
                    Source Monster is a high-performance collective of premier
                    freelancers. We don't operate like a slow, traditional agency. We
                    are a "Task Force" of specialized experts who come together to
                    execute complex digital missions with surgical precision.
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-secondary/5 rounded-xl flex items-center justify-center text-secondary shrink-0">
                            <i data-lucide="target" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-slate-900">Alpha Mission</h4>
                            <p class="text-sm text-slate-500">
                                Empowering brands with aggressive digital growth.
                            </p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-primary/5 rounded-xl flex items-center justify-center text-primary shrink-0">
                            <i data-lucide="eye" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-slate-900">The Vision</h4>
                            <p class="text-sm text-slate-500">
                                Setting the global standard for remote execution.
                            </p>
                        </div>
                    </div>
                </div>

                <button class="bg-dark text-white px-10 py-5 rounded-[2rem] font-bold text-lg hover:shadow-2xl transition-all">
                    Learn More Story
                </button>
            </div>
        </div>
    </div>
</section>

<style>
	.text-gradient {
		background: linear-gradient(to right, #FF4D1C, #FF8E6E);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
</style>

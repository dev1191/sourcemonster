---
---
<!-- Navigation -->
<nav class="fixed w-full z-50 transition-all duration-500 top-0 left-0" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 transition-all duration-500" id="nav-container">
	<div class="flex justify-between items-center glass-card px-4 sm:px-8 py-3 sm:py-4 rounded-2xl sm:rounded-3xl transition-all duration-500" id="nav-content">
	  <a href="#home" class="flex items-center group cursor-pointer">
		<img
		  src="/assets/images/logo.png"
		  alt="Source Monster"
		  class="h-11 sm:h-14 w-auto group-hover:scale-105 transition-transform"
		/>
	  </a>

	  <div class="hidden lg:flex items-center space-x-8 text-[11px] font-bold uppercase tracking-[0.2em] text-slate-500">
		<a href="#home" class="hover:text-primary transition-colors">Home</a>
		<a href="#about" class="hover:text-primary transition-colors">About</a>
		<a href="#services" class="hover:text-primary transition-colors">Solutions</a>
		<a href="#team" class="hover:text-primary transition-colors">Team</a>
		<a href="#workflow" class="hover:text-primary transition-colors">Tactics</a>
	  </div>

	  <div class="flex items-center space-x-2 sm:space-x-4">
		<a
		  href="#contact"
		  class="hidden xs:block bg-dark text-white px-4 sm:px-6 py-2 sm:py-3 rounded-xl sm:rounded-2xl text-xs sm:text-base font-bold hover:bg-primary hover:text-white transition-all transform hover:-translate-y-1 active:scale-95 shadow-xl shadow-primary/10"
		>
		  Get A Quote
		</a>
		<button
		  id="menu-toggle"
		  class="lg:hidden p-2 text-slate-600 hover:text-primary transition-colors relative"
		>
		  <i
			data-lucide="menu"
			class="menu-icon w-6 h-6 sm:w-8 sm:h-8 transition-all"
		  ></i>
		  <i
			data-lucide="x"
			class="close-icon hidden w-6 h-6 sm:w-8 sm:h-8 transition-all"
		  ></i>
		</button>
	  </div>
	</div>
  </div>

  <div id="mobile-menu" class="hidden absolute top-full left-0 w-full mt-2 px-4 sm:px-6 lg:hidden">
	<div class="glass-card rounded-[2rem] sm:rounded-[2.5rem] p-6 sm:p-8 space-y-4 shadow-2xl border border-white/10">
	  <a href="#home" class="flex items-center justify-between text-lg font-black hover:text-primary transition-colors group">Home
		<i data-lucide="chevron-right" class="w-5 h-5 opacity-0 group-hover:opacity-100 transition-all"></i>
	  </a>
	  <a href="#about" class="flex items-center justify-between text-lg font-black hover:text-primary transition-colors group">About
		<i data-lucide="chevron-right" class="w-5 h-5 opacity-0 group-hover:opacity-100 transition-all"></i>
	  </a>
	  <a href="#services" class="flex items-center justify-between text-lg font-black hover:text-primary transition-colors group">Solutions
		<i data-lucide="chevron-right" class="w-5 h-5 opacity-0 group-hover:opacity-100 transition-all"></i>
	  </a>
	  <a href="#team" class="flex items-center justify-between text-lg font-black hover:text-primary transition-colors group">Team
		<i data-lucide="chevron-right" class="w-5 h-5 opacity-0 group-hover:opacity-100 transition-all"></i>
	  </a>
	  <a href="#workflow" class="flex items-center justify-between text-lg font-black hover:text-primary transition-colors group">Tactics
		<i data-lucide="chevron-right" class="w-5 h-5 opacity-0 group-hover:opacity-100 transition-all"></i>
	  </a>
	  <div class="pt-4 border-t border-slate-100/10">
		<a href="#contact" class="block w-full bg-primary text-white text-center py-4 rounded-2xl font-bold hover:bg-dark transition-all shadow-lg shadow-primary/20">Get A Quote</a>
	  </div>
	</div>
  </div>
</nav>

<script is:inline>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.querySelector('.menu-icon');
  const closeIcon = document.querySelector('.close-icon');

  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      menuIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
    });
  }

  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  const navContainer = document.getElementById('nav-container');
  const navContent = document.getElementById('nav-content');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navContainer.classList.remove('py-4');
      navContainer.classList.add('py-2');
      navContent.classList.add('shadow-2xl');
    } else {
      navContainer.classList.add('py-4');
      navContainer.classList.remove('py-2');
      navContent.classList.remove('shadow-2xl');
    }
  });
</script>
